APP_NAME=Atlas AI Assistant
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite:///./atlas_assistant.db
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
# Claude / Anthropic
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
GOOGLE_MCP_BASE_URL=
GOOGLE_MCP_API_KEY=
# Google Calendar API (OAuth 2.0)
# Baixe o arquivo de credenciais em: Google Cloud Console > APIs & Services > Credentials
# Crie um OAuth 2.0 Client ID do tipo "Desktop app" e salve o JSON no path abaixo.
# O token será gerado automaticamente na primeira execução via browser.
GOOGLE_CREDENTIALS_PATH=credentials/google_oauth_credentials.json
GOOGLE_TOKEN_PATH=credentials/google_token.json
GOOGLE_CALENDAR_ID=primary
# Google Drive API
# Optional: restrict /drive/files listing to a specific folder.
# Leave empty to list all accessible files in Drive root.
GOOGLE_DRIVE_ROOT_FOLDER=
# Microsoft Graph (Outlook) — OAuth2 PublicClientApplication + PKCE (sem client_secret)
# 1. Registre um app em: https://portal.azure.com > Azure AD > App registrations
# 2. Tipo: "Mobile and desktop applications" (public client)
# 3. Adicione a permissao delegada Mail.Read
# 4. Copie o Application (client) ID abaixo
MICROSOFT_CLIENT_ID=
# Tenant: "common" (pessoal + corporativo), "consumers" (so pessoal), ou tenant ID
MICROSOFT_TENANT=common
MICROSOFT_TOKEN_CACHE_PATH=credentials/microsoft_token_cache.json
# Provider de email: "gmail" (default) ou "outlook"
EMAIL_PROVIDER=gmail
RSS_DEFAULT_FEEDS=https://feeds.reuters.com/reuters/businessNews,https://feeds.reuters.com/reuters/technologyNews
TIMEZONE=America/Sao_Paulo
LOG_LEVEL=INFO
